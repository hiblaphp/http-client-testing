{
    "name": "hiblaphp/http-client-testing",
    "description": "Feature Rich Plugin and Realistic Network Mock Simulation for Hibla Http Client",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Reymart A. Calicdan",
            "email": "reymart.calicdan06@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Hibla\\HttpClient\\Testing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "hiblaphp/http-client": "*"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "rcalicdan/config-loader": "^1.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "analyze": "./vendor/bin/phpstan analyse",
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest"
    }
}
